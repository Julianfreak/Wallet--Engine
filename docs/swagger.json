{
    "swagger": "2.0",
    "info": {
        "description": "Motor de billetera digital con transacciones atómicas.",
        "title": "Wallet-Engine API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8082",
    "basePath": "/",
    "paths": {
        "/accounts": {
            "get": {
                "description": "Devuelve los detalles y saldo actual de una cuenta mediante su ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "accounts"
                ],
                "summary": "Obtiene una cuenta",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID de la cuenta",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Respuesta exitosa",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/transfers": {
            "post": {
                "description": "Transfiere fondos de una cuenta origen a una cuenta destino garantizando la atomicidad de la operación en base de datos.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transfers"
                ],
                "summary": "Realiza una transferencia",
                "parameters": [
                    {
                        "description": "JSON con origin_id, destination_id y amount",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transferencia exitosa",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Datos inválidos o fondos insuficientes",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Error interno del servidor",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}